# Application
APP_ENV=production
# Render/Koyeb biasanya menyediakan PORT otomatis.
# Isi APP_PORT hanya jika menjalankan production config secara manual.
APP_PORT=
SEED_DEFAULT_USERS=false
SEED_DUMMY_DATA=false

# MySQL-compatible database
# Rekomendasi gratis: TiDB Cloud Starter.
DB_HOST=gateway01.ap-northeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=2rc6WJWWWEoJuvc.root
DB_PASSWORD=vyimYB2bwnDoGxXs
DB_NAME=panganku
DB_TLS=true
DB_MAX_IDLE_CONNS=5
DB_MAX_OPEN_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30

# Redis
# Rekomendasi gratis: Upstash Redis. Pakai URL rediss:// dari dashboard Upstash.
REDIS_URL=REDIS_URL=rediss://default:gQAAAAAAAcXBAAIgcDIxY2FmMjU0MGY3N2Y0ZjY0OGVmNDkzYWJjZGY0NjliOA@one-silkworm-116161.upstash.io:6379

# CORS
# Isi setelah URL Flutter Web jadi. Pisahkan dengan koma jika lebih dari satu.
CORS_ALLOWED_ORIGINS=https://your-frontend.pages.dev,https://your-frontend.netlify.app

# Security
JWT_SECRET=change-this-to-a-long-random-secret

# Optional integrations
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
TELEGRAM_BOT_TOKEN=
